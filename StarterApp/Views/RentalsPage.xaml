<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StarterApp.Views.RentalsPage"
    Title="Rentals">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label
            Text="Rental Requests"
            FontSize="24"
            FontAttributes="Bold" />

        <CollectionView ItemsSource="{Binding Rentals}">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame Padding="10" Margin="0,5">

                        <VerticalStackLayout Spacing="10">

                            <Label
                                Text="{Binding ItemTitle}"
                                FontAttributes="Bold"
                                FontSize="18"/>

                            <Label
                                Text="{Binding BorrowerName}" />

                            <Label
                                Text="{Binding Status}" />

                            <HorizontalStackLayout Spacing="10">

                                <Button
                                Text="Approve"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveRentalCommand}"
                                CommandParameter="{Binding .}"
                                IsEnabled="{Binding IsPending}" />

                            <Button
                                Text="Reject"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectRentalCommand}"
                                CommandParameter="{Binding .}"
                                IsEnabled="{Binding IsPending}" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>